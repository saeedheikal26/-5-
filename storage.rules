rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{allPaths=**} {
      // Allow any authenticated user to upload a receipt
      // The filename includes the UID to avoid collisions
      allow write: if request.auth != null;
      
      // Allow authenticated users (including admins) to read receipts
      allow read: if request.auth != null;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
